{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "opener:allow-open-path",
      "allow": [{ "path": "**" }]
    },
    "dialog:default"
  ]
}